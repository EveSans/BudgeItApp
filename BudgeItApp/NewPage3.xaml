<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BudgeItApp.ViewModels"
             x:Class="BudgeItApp.NewPage3"
             Title="NewPage3"
             BackgroundColor="White">

    
    <ContentPage.BindingContext>
        <vm:SplitViewModel />
    </ContentPage.BindingContext>


    <StackLayout >
        <StackLayout VerticalOptions="Start">
            <Image Margin="0,-30,0,0"
                    Source="blogo.png"
                    HeightRequest="140"
                    Aspect="AspectFit"
                    SemanticProperties.Description="logo"/>
            <Frame BorderColor="#dfffb3" BackgroundColor="#dfffb3" Margin="0,-40,0,9" MaximumHeightRequest="70">
                <Label 
                    Text="Split"
                    FontSize="20"
                    TextColor="MidnightBlue"
                    FontAttributes="Bold"
                    VerticalOptions="Start" 
                    HorizontalOptions="Center" />
            </Frame>
        </StackLayout>

        <!-- Display Percentage Results -->
        <StackLayout VerticalOptions="EndAndExpand" >
            <Frame BackgroundColor="#CDECB9" BorderColor="#CDECB9" CornerRadius="0" Margin="15,0">
                <Label Text="{Binding Savings, StringFormat='Savings: ${0:0.00}'}" FontSize="16" />
            </Frame>
            <Frame BackgroundColor="#A2D087" BorderColor="#A2D087" CornerRadius="0" Margin="15,0">
                <Label Text="{Binding Spending, StringFormat='Spending: ${0:0.00}'}" FontSize="16" />
            </Frame>
            <Frame BackgroundColor="#8ACE63" BorderColor="#8ACE63" CornerRadius="0" Margin="15,0">
                <Label Text="{Binding Other, StringFormat='Other: ${0:0.00}'}" FontSize="16" />
            </Frame>
        </StackLayout>


        <Button Margin="33"
            x:Name="CounterBtn" BackgroundColor="DarkGreen" CornerRadius="26" WidthRequest="85"
            Text="Deposit" 
            SemanticProperties.Hint="Navigate to Page 1"
            Clicked="GoPone"
            HorizontalOptions="Center" />
    </StackLayout>
</ContentPage>
